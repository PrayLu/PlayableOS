  "interactions": {
    "intros": {
      "intro": {
        "headline": "破心中贼",
        "tagline": "告谕浰头巢贼 · 情境演练",
        "logo_text": "阳明",
        "body": "正德十二年，王阳明巡抚南赣。\n\n平漳寇后，他知贼中多是被胁从之人，不忍「不教而杀」，先遣告谕。\n\n你，是浰头山中一个被卷入的普通山民。\n\n接下来六关，你将听见告谕、面对同伙、在良知与恐惧之间做出选择。",
        "cta": "进入山中"
      }
    },
    "dialogues": {
      "dialogue_fall": {
        "character_id": "colleague",
        "lines": [
          {
            "text": "还愣什么？官军迟早要打过来。你在山下那几亩薄田，催税的吏员可曾饶过你？",
            "emotion": "serious"
          },
          {
            "text": "阿七跟你说实话：在这山上，至少能吃饱。阳明？听说是个读书人巡抚，未必真敢进山。",
            "emotion": "neutral"
          },
          {
            "text": "今日营前来了传谕使，说是巡抚亲笔告谕。弟兄们都在听，你也去。",
            "emotion": "concerned",
            "sfx": "whoosh"
          }
        ]
      },
      "dialogue_proclamation": {
        "character_id": "partner",
        "lines": [
          {
            "text": "巡抚告谕：本院专以弭盗安民为职。审知漳寇之中，倡恶不过四五十人，党恶四千余，其余多系一时被胁，不觉惨然兴哀。",
            "emotion": "serious"
          },
          {
            "text": "人情之所共耻，莫过于身被为盗之名。若有人骂尔等为盗，尔必怫然而怒。尔等岂可心恶其名而身蹈其实？",
            "emotion": "encouraging"
          },
          {
            "text": "尔等各人有父母，各人有妻子，如何忍作这样事？若速改悔，既往不咎。若仍旧为恶，官兵必至。",
            "emotion": "serious"
          },
          {
            "text": "闻尔等辛苦为贼，所得苦亦不多。何不用为贼的勤苦精力，用于耕农商贾，安享逸乐？",
            "emotion": "encouraging"
          }
        ]
      },
      "dialogue_bridge": {
        "character_id": "mentor",
        "lines": [
          {
            "text": "我每为尔等思念及此，辄至于终夜不能安寝，亦无非欲为尔等寻一生路。",
            "emotion": "encouraging"
          },
          {
            "text": "今谓我全无杀尔之心，亦是诳尔；若谓我必欲杀尔，又非吾之本心。譬如父母十子，二人背逆，父母须除去二人，然后八人安生。",
            "emotion": "serious"
          },
          {
            "text": "若此二子一旦悔恶迁善，号泣投诚，为父母者亦必哀悯而收之。不忍杀其子，乃父母之本心也。",
            "emotion": "encouraging",
            "sfx": "success"
          }
        ]
      },
      "dialogue_closing": {
        "character_id": "mentor",
        "lines": [
          {
            "text": "民吾同胞，尔等皆吾赤子。我不能抚恤尔等而至于杀尔，痛哉痛哉。",
            "emotion": "concerned"
          },
          {
            "text": "破山中贼易，破心中贼难。山中贼已破，尔心中之贼，须尔自破。",
            "emotion": "serious"
          },
          {
            "text": "好自思量。我言已无不尽，我心已无不尽。",
            "emotion": "encouraging",
            "sfx": "success"
          }
        ]
      }
    },
    "choices": {
      "choice_1": {
        "prompt": "第一关 · 落草之由。阿七问你：你到底是迫不得已，还是心里也认了这条道？回想你入山那日——",
        "character_id": "colleague",
        "options": [
          {
            "id": "a",
            "text": "我是被大户逼债、被吏员催税，一时错起念头，并非甘愿为盗",
            "feedback": "告谕中所言：或有不得已者，为官府所迫，为大户所侵，一时错起念头。此苦情，甚是可悯。但须真切悔悟，不可久蹈其途。",
            "score": 85
          },
          {
            "id": "b",
            "text": "既然上了山，就要够狠，不然被人欺负",
            "feedback": "心恶盗名而身蹈其实，是为甘愿。阳明言：其中倡恶者有限，若仍旧为恶，必不宽贷。",
            "score": 15
          },
          {
            "id": "c",
            "text": "我入山是被裹挟，但心里一直不安，想寻机会离开",
            "feedback": "良知未泯。告谕正是为「一时被胁」之人寻一生路。死人求生路，须如当初活人寻死路一般，拚死出来。",
            "score": 95
          }
        ]
      },
      "choice_2": {
        "prompt": "第二关 · 同此心。传谕使念到：若有人掠尔妻女，尔必怀恨切骨。又念：尔等各人有父母妻子。你想起家中老母……",
        "character_id": "partner",
        "options": [
          {
            "id": "a",
            "text": "当众落泪，不再隐瞒：我想回家见娘",
            "feedback": "「人同此心，尔宁独不知？」羞耻与思念，正是良知显现。阳明抚谕，如父母待逆子，哀悯而收之。",
            "score": 95
          },
          {
            "id": "b",
            "text": "低头不语，夜里独自哭，白天仍跟队行事",
            "feedback": "良知已动，但尚未知行合一。告谕言：今欲改行从善，乃是死人求生路，乃反不敢，何也？",
            "score": 55
          },
          {
            "id": "c",
            "text": "阿七说得对，这是读书人的把戏，不能信",
            "feedback": "心多猜疑，久习恶毒。阳明言：岂知我无故杀一鸡犬尚且不忍，况人命关天。",
            "score": 20
          }
        ]
      },
      "choice_3": {
        "prompt": "第三关 · 同伙压力。池头领怀疑你动摇，命你在下次劫掠中「杀一人立威」，以证忠心。",
        "character_id": "colleague",
        "sfx": "warning",
        "options": [
          {
            "id": "a",
            "text": "照做，先保命再说",
            "feedback": "忍于杀人，心多猜疑，与告谕所戒「身蹈其实」无异。轻易伤人，冥冥之中，断有还报。",
            "score": 5
          },
          {
            "id": "b",
            "text": "假意答应，暗中寻路下山，向官军投诚",
            "feedback": "知行合一。告谕：若尔等肯拚死出来，求改行从善，我官府岂有必要杀汝之理？",
            "score": 90
          },
          {
            "id": "c",
            "text": "当场拒绝：我不杀无辜，要杀便杀我",
            "feedback": "勇气可嘉，致良知于危境。亦须审时度势，寻机投诚，勿徒逞血气。",
            "score": 75
          }
        ]
      },
      "choice_4": {
        "prompt": "第四关 · 降或不降。官军已在山下立招抚牌，既往不咎。你已到山口，阿七在身后喊：回来！",
        "character_id": "colleague",
        "options": [
          {
            "id": "a",
            "text": "抛下兵器，号泣投诚，请求归籍",
            "feedback": "「若速改悔，既往不咎。」阳明视尔为良民，抚如赤子。悔恶迁善，即顺父母本心。",
            "score": 100
          },
          {
            "id": "b",
            "text": "再观望几日，看风头再说",
            "feedback": "迟疑之间，良机易失。告谕言：一年不尽至于两年，两年不尽至于三年。",
            "score": 40
          },
          {
            "id": "c",
            "text": "跟阿七回寨，与官军对抗",
            "feedback": "仍旧为恶，非我杀之，乃天杀之。阳明本无好杀之心，然尔等若害良民，则不得不剿。",
            "score": 10
          }
        ]
      },
      "choice_5": {
        "prompt": "第五关 · 今时之思。团队里有人曾走过弯路，现已改正。有人主张永久封杀，有人主张给路径与监督。你如何看？",
        "character_id": "mentor",
        "options": [
          {
            "id": "a",
            "text": "一律开除，以儆效尤，不给第二次机会",
            "feedback": "未辨被迫与甘愿，亦未给改行从善之路。告谕之智，在威恩并济，非无原则纵容。",
            "score": 35
          },
          {
            "id": "b",
            "text": "视其是否真切悔悟、是否再犯，给路径与监督，如抚新归之民",
            "feedback": "深得告谕之心：悔恶迁善，哀悯而收之；屡教不改首恶，则必剿。致良知，亦须明边界。",
            "score": 95
          },
          {
            "id": "c",
            "text": "不论对错，一律包庇自己人",
            "feedback": "此非仁，是私。阳明言：不能抚恤而至于杀，痛哉——正因顾念良民与赤子。",
            "score": 15
          }
        ]
      }
    },
    "feedbacks": {},
    "reflections": {
      "reflection": {
        "prompt": "告谕读罢，阳明言「破心中贼难」。写一种你心中的「贼」（如贪、惧、怨、傲），以及你想如何启用良知。",
        "placeholder": "例如：我心中之贼是惧——遇压力则随大流。愿学告谕，在 shame 中看见良知……"
      }

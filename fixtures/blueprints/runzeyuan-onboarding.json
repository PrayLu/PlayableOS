  "interactions": {
    "intros": {
      "intro": {
        "headline": "欢迎加入润泽园大家庭",
        "tagline": "五关入职演练 · Runzeyuan",
        "logo_text": "润泽",
        "body": "Hi，亲爱的新伙伴！\n\n本次演练共五关，穿插互动对话与情境选择：\n① 高压线  ② 考勤  ③ 心学文化  ④ 用餐礼仪  ⑤ 诚信合规\n\n请佩戴耳机，跟随悦迪姐一起完成。",
        "cta": "开始五关演练"
      }
    },
    "dialogues": {
      "dialogue_welcome": {
        "character_id": "mentor",
        "lines": [
          { "text": "你好，我是悦迪姐，来自心力资源中心。欢迎加入润泽园，这里既是心学教育，也是我们的精神家园。", "emotion": "encouraging" },
          { "text": "今天不背手册。你会亲身走进五个新人都会遇到的场景，每一关都是一次真实的选择。", "emotion": "serious" },
          { "text": "先说我们的使命，助力企业战略创新。愿景，成为企业家首选的教育品牌。", "emotion": "neutral" }
        ]
      },
      "dialogue_values": {
        "character_id": "mentor",
        "lines": [
          { "text": "润泽园有四句价值观。第一，人生重大秘密，是心中拥有无尽宝藏。第二，人生重大真理，是行为作用与反作用。", "emotion": "serious" },
          { "text": "第三，人生重大战略，是建设自己心灵品质。第四，人生重大价值，是成就他人建设心灵品质。", "emotion": "serious" },
          { "text": "我们期待你四深：对自己深沉厚重，对他人深情厚意，对决策深思熟虑，对经典深入浅出。准备好了吗？第一关开始。", "emotion": "encouraging", "sfx": "whoosh" }
        ]
      },
      "dialogue_bridge_1": {
        "character_id": "mentor",
        "lines": [
          { "text": "第一关完成。记住，四条高压线无例外：禁止婚外情和内部恋爱、禁止行贿受贿、禁止弄虚作假、禁止透露工资。", "emotion": "serious" },
          { "text": "接下来第二关，考勤。在润泽园，飞书不只是聊天工具，也是你的考勤与审批入口。", "emotion": "encouraging" }
        ]
      },
      "dialogue_bridge_2": {
        "character_id": "partner",
        "lines": [
          { "text": "干得不错。考勤规范看起来是小事，但体现的是对规则的尊重，也是对自己时间的管理。", "emotion": "encouraging" },
          { "text": "第三关是心学文化。润泽园不只是来上班，更是来建设心灵品质。呵护成长群里的每一次分享，都是修行。", "emotion": "neutral" }
        ]
      },
      "dialogue_bridge_3": {
        "character_id": "mentor",
        "lines": [
          { "text": "心学文化这一关，核心是真诚。必修《文化自信 民族复兴》，每周读两遍，重点在心道德事四部曲。", "emotion": "serious" },
          { "text": "第四关，我们去公司一层餐厅。润泽园的用餐文化，也是文化的一部分。", "emotion": "encouraging", "sfx": "whoosh" }
        ]
      },
      "dialogue_bridge_4": {
        "character_id": "colleague",
        "lines": [
          { "text": "明哥跟你说，在润泽园吃饭有个规矩，不剩一粒米。不是形式主义，是惜福和对他人的尊重。", "emotion": "encouraging" },
          { "text": "最后一关，诚信。高压线里有一条，严禁利用工作之便行贿或收贿。这是保护你，也是保护公司。", "emotion": "serious" }
        ]
      },
      "dialogue_closing": {
        "character_id": "mentor",
        "lines": [
          { "text": "五关全部完成，恭喜你。入职第一周，记得提交入职资料、开通门禁胸牌、加入部门群和公司大群。", "emotion": "encouraging" },
          { "text": "有问题，飞书搜索 HR 服务台。期待你在润泽园：总是发现问题，总是探究本质，总是坚定信心，总是胸怀理想。", "emotion": "happy", "sfx": "success" }
        ]
      }
    },
    "choices": {
      "choice_1": {
        "prompt": "第一关 · 高压线。午餐时，明哥凑过来低声问：你 offer 多少啊？咱们都是一家人，透露一下呗。周围还有其他新伙伴。你会？",
        "character_id": "colleague",
        "options": [
          { "id": "a", "text": "委婉告诉一个大概范围", "feedback": "违反高压线。入职指南规定，严禁透露自己工资给他人，违者辞退。", "score": 0 },
          { "id": "b", "text": "笑着打岔：明哥，指南说工资不能聊哦", "feedback": "很好。工资保密是制度红线，应温和而坚定地拒绝。", "score": 95 },
          { "id": "c", "text": "不回答，但私下用飞书告诉另一位同事", "feedback": "同样违反高压线。无论对谁，透露工资都是红线。", "score": 5 }
        ]
      },
      "choice_2": {
        "prompt": "第二关 · 考勤。芳野姐约你下午去朝阳见客户，15 点到 17 点不在园区。明哥说，进公园范围打卡就行，不用走审批。你会？",
        "character_id": "partner",
        "options": [
          { "id": "a", "text": "听明哥的，进公园打卡就好", "feedback": "不规范。外出须按考勤制度在飞书提交申请并完成审批。", "score": 25 },
          { "id": "b", "text": "先在飞书提交外出申请，审批后再出发", "feedback": "正确。严谨守诺，是对自己也是对组织的负责。", "score": 95 },
          { "id": "c", "text": "先出门见客户，回来再补审批", "feedback": "先斩后奏不符合制度。审批应先于行动。", "score": 35 }
        ]
      },
      "choice_3": {
        "prompt": "第三关 · 心学文化。第二周，需在呵护成长群发学习心得。今天读了心道德事，但很忙。明哥发来昨天的心得说，复制改改就行。你会？",
        "character_id": "colleague",
        "options": [
          { "id": "a", "text": "复制明哥的心得，改几个词发出去", "feedback": "违背学习文化。呵护成长群的意义是真实成长，彼此照亮。", "score": 10 },
          { "id": "b", "text": "哪怕只有三句话，也写真实感受发出去", "feedback": "非常好。对经典深入浅出，真诚比完美更重要。", "score": 100 },
          { "id": "c", "text": "今天太忙，先不发，明天再说", "feedback": "呵护成长群要求每日分享。主动学习是建设心灵品质的践行。", "score": 45 }
        ]
      },
      "choice_4": {
        "prompt": "第四关 · 用餐文化。公司餐厅午餐，你打多了菜吃不完。明哥说，剩一点没事，反正会倒掉。你会？",
        "character_id": "colleague",
        "options": [
          { "id": "a", "text": "剩一点没关系，下次注意", "feedback": "润泽园用餐文化要求不剩一粒米。惜福是对资源的尊重。", "score": 30 },
          { "id": "b", "text": "尽量吃完，下次按需取餐，不需要用餐提前和报餐员说", "feedback": "正确。不剩一粒米是用餐文化，提前沟通避免浪费也是。", "score": 95 },
          { "id": "c", "text": "把剩的给同事帮忙吃", "feedback": "心意可以理解，但自己取餐自己负责更好。按需取餐、不浪费是根本。", "score": 55 }
        ]
      },
      "choice_5": {
        "prompt": "第五关 · 诚信合规。采购供应商私下微信说，如果订单给他们，可以感谢一下你个人，金额不大，行业惯例。你会？",
        "character_id": "partner",
        "sfx": "phone_ring",
        "options": [
          { "id": "a", "text": "拒绝并上报，坚持按公司流程公正评估", "feedback": "完美。严禁行贿受贿是高压线，诚信是润泽园不可触碰的底线。", "score": 100 },
          { "id": "b", "text": "先收下，看看产品是否更好", "feedback": "一旦接受好处，判断就会失真。诚信要求零容忍。", "score": 10 },
          { "id": "c", "text": "不要个人好处，但暗示可以加快流程", "feedback": "变相利益交换同样违反诚信原则。", "score": 35 }
        ]
      }
    },
    "feedbacks": {},
    "reflections": {
      "reflection": {
        "prompt": "五关演练结束。你觉得自己最需要刻意练习的是哪一点？制度合规、主动学习、还是心学践行？写一两句真实体会。",
        "placeholder": "例如：我意识到高压线不是束缚，而是保护 everyone's 信任……"
      }
    },
    "results": {
      "result": {
        "headline": "五关演练完成，欢迎正式启程",
        "summary_template": "你在润泽园新人五关演练中获得 {score} 分。{passed_message}",
        "growth_suggestions": [
          "完成第一周 checklist：入职资料、门禁胸牌、部门群",
          "飞书搜索 HR 服务台，下载润泽园 APP 开始诵读打卡",
          "加入呵护成长群，每日分享真实学习心得"
        ]
      }

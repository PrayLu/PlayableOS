  "metadata": {
    "id": "corporate-culture-001",
    "version": "0.2.0",
    "title": "企业文化入门 · 价值观情境演练",
    "description": "沉浸式视听互动体验：通过真实职场情境，理解并践行公司核心价值观。",
    "language": "zh-CN",
    "duration_minutes": 12,
    "type": "simulation",
    "tags": ["企业文化", "价值观", "新员工", "MVP"]
  },
  "capability": {
    "target": "企业文化理解与践行",
    "learning_objective": "能够在日常工作中识别价值观冲突，并做出符合公司文化的正确判断与行动。",
    "rubric": [
      "能准确理解四项核心价值观的含义",
      "能在客户利益与内部流程冲突时优先客户",
      "能在跨部门协作中体现团队合作精神",
      "能在面对利益诱惑时坚持诚信正直"
    ]
  },
  "scenario": {
